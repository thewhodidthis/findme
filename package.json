{
  "name": "@thewhodidthis/findme",
  "version": "0.1.1",
  "description": "Just another take on the old sosumi class",
  "keywords": [
    "icloud",
    "iphone",
    "sosumi"
  ],
  "jsnext:main": "index.js",
  "main": "index.js",
  "homepage": "https://github.com/thewhodidthis/findme#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/findme.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/findme/issues"
  },
  "directories": {
    "example": "example"
  },
  "config": {
    "jscsrc": ".jscsrc"
  },
  "eslintConfig": {
    "extends": "airbnb-base",
    "rules": {
      "comma-dangle": 0,
      "no-console": 0,
      "strict": 0
    },
    "env": {
      "node": true
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "cleanup": "rm -f *.log",
    "lint": "eslint index.js | tee eslint.log",
    "postlint": "find eslint.log -size 0 -print0 | xargs -0 rm",
    "preversion": "npm run cleanup"
  },
  "engines": {
    "node": ">=4.2.4",
    "npm": ">=3.5.3"
  },
  "dependencies": {},
  "devDependencies": {
    "eslint": "latest"
  },
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (https://www.thewhodidthis.com)",
  "license": "Unlicense"
}
